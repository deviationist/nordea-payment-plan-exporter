# Nordea login — used by fetch.sh (kept out of git)
SSN=
BANKID_PWD=
# LOAN_ACCOUNT: account number (e.g. 1234.56.78901) — only to pick among >1 loan
LOAN_ACCOUNT=

# Downpayment scenario — used by build.sh / compare.sh
# DOWNPAYMENT: temporary extra downpayment in kr, e.g. 500000 (empty/0 = initial plan only)
DOWNPAYMENT=
# DOWN_DATE: when it is paid onto the loan, YYYY-MM-DD (default: first term)
DOWN_DATE=
# UP_DATE: when the uploan (opplåning) repays it, YYYY-MM-DD (e.g. 2030-01-01)
UP_DATE=
